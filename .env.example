# API
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
AUTO_MIGRATE_ON_STARTUP=true

# Postgres — Supabase pooler (host aws-…pooler.supabase.com). Direct db.<ref>.supabase.co
# is often IPv6-only on Free/Pro and breaks Docker.
#
# Session pooler (port 5432): default; full Postgres session semantics.
# Transaction pooler (port 6543): higher multiplexing; the API disables psycopg prepared
# statements automatically when the URL port is 6543 (required for PgBouncer transaction mode).
# Replace the driver prefix with postgresql+psycopg:// when copying from the dashboard.
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:replace-with-db-password@aws-<n>-<region>.pooler.supabase.com:5432/postgres
# DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:...@aws-<n>-<region>.pooler.supabase.com:6543/postgres

# Auth — Supabase GoTrue + JWT (separate from DATABASE_URL / Postgres)
# Login uses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY (already required for Storage).
# JWT secret: Project Settings → API → JWT Secret
# Leave empty to disable JWT validation in local development (APP_ENV=development only).
SUPABASE_JWT_SECRET=
# Optional but strongly recommended for production — validates token issuer.
# Format: https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_ISSUER=

# Agents / investigate_trade (read directly from os.environ, not Settings)
ANTHROPIC_API_KEY=

# --- Supabase Storage (ML pipeline artefacts) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=trade-surveillance-artifacts
# Pipeline storage paths (defaults shown — override only if needed)
SUPABASE_FEATURES_KEY=features/features.parquet
SUPABASE_MODEL_KEY=model/isolation_forest.pkl
SUPABASE_MEDIANS_KEY=model/medians.json

# Vercel: set NEXT_PUBLIC_API_BASE_URL in the Next.js project, not here.
